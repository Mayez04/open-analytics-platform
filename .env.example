# =============================================================================
# Open Analytics Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment:
#
#   cp .env.example .env          (Linux / macOS)
#   copy .env.example .env        (Windows)
#
# Preset profiles are available in config/env/:
#   - development.env.example   local development (simple credentials)
#   - pilot.env.example           client demo / pilot (stronger credentials)
#
# See docs/configuration.md for full documentation.
# =============================================================================

# --- Deployment mode ---------------------------------------------------------
# development = local work, simple passwords, debug-friendly defaults
# pilot       = client demo, stronger secrets, production-like settings
DEPLOYMENT_MODE=development

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=analytics_user
POSTGRES_PASSWORD=analytics_password
POSTGRES_DB=analytics_warehouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_INTERNAL_PORT=5432

# --- MinIO -------------------------------------------------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_ENDPOINT=http://minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=bronze

# --- Airflow -----------------------------------------------------------------
AIRFLOW_WEB_PORT=8081
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0nIe3aY=
AIRFLOW_SECRET_KEY=change-me-airflow-secret-key

# --- Superset ----------------------------------------------------------------
SUPERSET_PORT=8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@superset.com
SUPERSET_SECRET_KEY=change-me-superset-secret-key

# --- Keycloak (Phase 6) ------------------------------------------------------
#KEYCLOAK_PORT=
#KEYCLOAK_ADMIN_USER=
#KEYCLOAK_ADMIN_PASSWORD=

# --- AI Assistant (Phase 5) --------------------------------------------------
#LLM_PROVIDER=
#LLM_API_KEY=
#LLM_MODEL=

# --- DHIS2 pipeline  -----------------------------------------------
DHIS2_BASE_URL=https://play.im.dhis2.org/stable-2-41-8-1
DHIS2_USERNAME=admin
DHIS2_PASSWORD=district
