# Pilot / demo mode — copy to project root as .env
# cp config/env/pilot.env.example .env
#
# IMPORTANT: Replace every CHANGE_ME_* value before running a client demo.

DEPLOYMENT_MODE=pilot

POSTGRES_USER=analytics_user
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=analytics_warehouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_INTERNAL_PORT=5432

MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_ENDPOINT=http://minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=bronze

AIRFLOW_WEB_PORT=8081
AIRFLOW_ADMIN_USER=airflow_admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_airflow_password
AIRFLOW_ADMIN_EMAIL=airflow-admin@example.com
AIRFLOW_FERNET_KEY=CHANGE_ME_generate_fernet_key
AIRFLOW_SECRET_KEY=CHANGE_ME_airflow_secret_key

SUPERSET_PORT=8088
SUPERSET_ADMIN_USER=superset_admin
SUPERSET_ADMIN_PASSWORD=CHANGE_ME_superset_password
SUPERSET_ADMIN_EMAIL=superset-admin@example.com
SUPERSET_SECRET_KEY=CHANGE_ME_superset_secret_key

KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USER=keycloak_admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_password

LLM_PROVIDER=openai
LLM_API_KEY=CHANGE_ME_llm_api_key
LLM_MODEL=gpt-4o-mini

DHIS2_BASE_URL=https://play.im.dhis2.org/stable-2-41-8-1
DHIS2_USERNAME=admin
DHIS2_PASSWORD=district
